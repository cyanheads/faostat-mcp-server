# ── Transport ──────────────────────────────────────────────────────────
# MCP_TRANSPORT_TYPE=stdio          # stdio | http (default: stdio)
# MCP_HTTP_PORT=3010                # HTTP port (default: 3010)
# MCP_HTTP_HOST=localhost           # HTTP host (default: localhost)
# MCP_HTTP_ENDPOINT_PATH=/mcp      # HTTP endpoint path (default: /mcp)
# MCP_HTTP_MAX_BODY_BYTES=1048576  # Max request body bytes; 413 over limit, 0 disables (default: 1048576)
# MCP_PUBLIC_URL=                  # Public origin behind a TLS-terminating proxy (e.g. https://mcp.example.com)

# ── Auth ──────────────────────────────────────────────────────────────
# MCP_AUTH_MODE=none                # none | jwt | oauth (default: none)
# MCP_AUTH_SECRET_KEY=              # JWT secret (required for jwt mode)

# ── Storage ───────────────────────────────────────────────────────────
# STORAGE_PROVIDER_TYPE=in-memory   # in-memory | filesystem | supabase | cloudflare-r2 | cloudflare-kv | cloudflare-d1

# ── Session ──────────────────────────────────────────────────────────
# MCP_SESSION_MODE=stateful         # stateful | stateless (default: stateful)

# ── Memory ───────────────────────────────────────────────────────────
# MCP_GC_PRESSURE_INTERVAL_MS=0     # Opt-in forced Bun.gc(true) interval, ms (Bun only). Drains old-gen backlog
                                    # under sustained HTTP load (issue #50). Try 60000 if RSS grows. Default: 0.

# ── Logging ───────────────────────────────────────────────────────────
# MCP_LOG_LEVEL=info                # debug | info | notice | warning | error

# ── Telemetry ─────────────────────────────────────────────────────────
# OTEL_ENABLED=false                          # Enable OpenTelemetry (default: false)
# OTEL_EXPORTER_OTLP_ENDPOINT=               # OTLP endpoint URL (e.g., http://localhost:4318)

# ── DataCanvas (SQL surface for large result sets) ───────────────────
# Enabled by default (DuckDB ships as a direct dependency). Set to `none` to
# disable analytical staging — the dataframe tools then report canvas_disabled
# and large queries refuse to spill. Keep =duckdb for the dataframe tools.
# CANVAS_PROVIDER_TYPE=duckdb

# ── FAOSTAT mirror ───────────────────────────────────────────────────
# Comma-separated domain codes to index into the local SQLite mirror. Domains
# outside this set show in faostat_list_domains but aren't queryable until added
# and re-synced. TCL (~17M rows) can be dropped on RAM-constrained hosts.
# FAOSTAT_DOMAINS=QCL,TCL,FBS,FS,RL,GLE,RFN,QV

# Directory for the per-domain SQLite stores + the shared dimension database.
# FAOSTAT_MIRROR_PATH=./.faostat-mirror

# Bulk-download service base URL (manifest + per-domain ZIPs).
# FAOSTAT_BULK_BASE_URL=https://bulks-faostat.fao.org/production

# Cron for the in-process incremental refresh (HTTP transport only). Omit to
# disable and run `bun run mirror:refresh` out-of-band instead.
# FAOSTAT_REFRESH_CRON=0 6 * * *
